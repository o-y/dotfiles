##
## Constants which may be referred to by any owned Zsh script
##

typeset -gxr CLR_BOLD='%B'
typeset -gxr CLR_UNBOLD='%b'
typeset -gxr CLR_PAL1='%F{1}'
typeset -gxr CLR_PAL2='%F{2}'
typeset -gxr CLR_PAL3='%F{3}'
typeset -gxr CLR_PAL4='%F{4}'
typeset -gxr CLR_PAL5='%F{5}'
typeset -gxr CLR_PAL6='%F{6}'
typeset -gxr CLR_RESET='%f%b'

typeset -gxr HL_BOLD="bold"
typeset -gxr HL_P3="fg=3"
typeset -gxr HL_P4="fg=4"
typeset -gxr HL_P5="fg=5"
typeset -gxr HL_P6="fg=6"